# Anthropic API Key (for Claude AI)
ANTHROPIC_API_KEY=sk-ant-...

# SendGrid API Key
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=newsletter@brite.co
SENDGRID_FROM_NAME=The BriteSide

# Google OAuth (for @brite.co login)
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...

# Slack Incoming Webhook (for #announcements)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Flask
FLASK_SECRET_KEY=...
PORT=5002
FLASK_DEBUG=true

# Access control
# Comma-separated allow-list of newsletter-team (editor) emails. Everyone else
# who signs in with @brite.co is a contributor (can submit, not build/send).
EDITOR_EMAILS=dylanne.crugnale@brite.co,dove@brite.co
# Machine-to-machine secret for Cloud Scheduler job endpoints (/api/jobs/*).
JOB_SECRET=
# Set to 'true' ONLY for local dev to bypass OAuth. NEVER set in production.
DEV_AUTH_MODE=false
# Optional display name for the dev stand-in user (defaults to 'Local Developer (dev)').
DEV_AUTH_NAME=

# Dedicated PUBLIC bucket for newsletter media, so drafts + employee PII in the
# private drafts bucket are never world-readable. Leave blank to keep media in
# the drafts bucket (not recommended for prod).
GCS_MEDIA_BUCKET=
